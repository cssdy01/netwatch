# NetWatch Backend — Environment Variables
# Copy to .env and fill in your values

# === REQUIRED ===
MONITOR_HOST=192.168.1.100        # Your server IP — shown in emails and footer
ADMIN_USER=admin
ADMIN_PASS=changeme123            # Plain text here — hashed on startup
JWT_SECRET=change-this-to-a-random-string-min-32-chars

# === MAIL — System Mail (mailx) ===
# NetWatch uses the server's own mailx/Postfix — no SMTP credentials needed.
# Install on Ubuntu:  sudo apt install mailutils
# Install on RHEL:    sudo dnf install mailx
MAIL_FROM_NAME=NetWatch Monitor
MAIL_FROM_EMAIL=alerts@192.168.1.100.local

# === OPTIONAL ===
PORT=3000
SESSION_HOURS=8
DEFAULT_N_THRESHOLD=2
PRUNE_DAYS=60
DATA_DIR=./data
